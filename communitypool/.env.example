# =============================================================================
# CommunityPool environment template
# =============================================================================
# Copy to `.env.local` for local Next.js development. Restart the dev server
# after changes.
#
# IMPORTANT — secret hygiene
# ---------------------------
# - Never store production secrets in local `.env` / `.env.local` files.
# - Production secrets must be configured in the hosting provider's secret
#   store (e.g. Vercel Project Settings → Environment Variables).
# - Rotate any secret that has been pasted into chat tools, screenshots,
#   shared logs, screen recordings, or ad-hoc debug scripts.
# - This file must contain placeholder values only. Never commit real keys.
#
# Pre-mainnet rotation checklist
# ---------------------------
# Before going live, rotate the following at the provider and set fresh
# values in the hosting platform (NOT in any committed file):
#   - Supabase service role key
#   - Supabase anon key
#   - Supabase Postgres database password (rotate at the dashboard; see below)
#   - Stripe secret key (live mode)
#   - Stripe webhook signing secret (live mode)
#   - Google OAuth client secret
#   - Alchemy API key
#   - Etherscan API key
#   - Upstash Redis REST token
#
# Supabase Postgres database password
# ---------------------------
# Do not store the Postgres database password in this file, in `.env`,
# `.env.local`, or any committed/uncommitted env template. Database
# passwords belong in:
#   - the Supabase CLI keychain (`supabase login`)
#   - the Supabase dashboard
#   - an OS keychain (macOS Keychain, 1Password, Bitwarden, etc.)
#   - a secret manager (Vercel encrypted env, Doppler, AWS Secrets Manager)
# If a database password is ever pasted into a prompt, log, screenshot,
# debug script, terminal history, or agent transcript, rotate it
# immediately via Supabase dashboard → Project → Settings → Database
# → Reset password.
# =============================================================================


# Optional. Bitcoin address lookups use mempool.space REST by default (Esplora-compatible).
# Set to another origin if you self-host (same `/api/address/...` and `/api/v1/prices` paths).
# MEMPOOL_API_BASE=https://mempool.space

# Etherscan API v2 key (https://docs.etherscan.io/getting-an-api-key). When set without
# `ALCHEMY_API_KEY`, address lookup uses Etherscan for balances and tx history on supported EVM
# networks; USD still uses Chainlink via JSON-RPC (set ALCHEMY_API_KEY or ALCHEMY_API_URL_ETH_*
# per network). When both keys are set, lookups default to Alchemy unless you force Etherscan:

# ETHERSCAN_API_KEY=

# --- Application-layer rate limiting (Upstash Ratelimit) ---
# Required for durable, multi-instance rate limiting in production. When BOTH
# variables are set, the helper at lib/security/rate-limit.ts uses Upstash
# Redis as the backing store. When unset, the helper falls back to a
# per-process in-memory limiter and logs a warning at startup — fine for
# local dev and CI, but DO NOT rely on it in production (each serverless
# instance keeps its own counters, so attackers can shard around it).
#
# Provision a free Upstash Redis database at https://console.upstash.com/redis
# and copy the REST URL + token below. No other configuration needed.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Supabase project (Dev vs Prod split) ---
# Two Supabase projects exist:
#   - CommunityPoolDev  (ref femdttcdyklzjmhwnzvu) — used by local dev and Vercel
#                          Preview deployments
#   - CommunityPoolProd (ref yturmkjltuxfmrewgicq) — used ONLY by Vercel Production
#                          deployments
# DO NOT put real Supabase URL/keys in this file or any committed env file.
# Local: keep Dev values in .env.local (uncommitted).
# Vercel: set the four variables below per-scope under
#   Project Settings → Environment Variables. Use:
#     - Production scope = CommunityPoolProd values
#     - Preview/Development scopes = CommunityPoolDev values
# All four variables MUST be present together for the same project — mixing
# Dev URL with a Prod anon key (or vice versa) will fail JWT validation
# silently and look like "invalid login credentials" in the UI.
#
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<legacy anon JWT — Project Settings → API → anon>
# SUPABASE_URL=https://<project-ref>.supabase.co     (server-side fallback used by lib/supabase/admin.ts)
# SUPABASE_SERVICE_ROLE_KEY=<legacy service_role JWT — server-side ONLY>
#
# The service_role key bypasses RLS. Required by:
#   - app/api/stripe/webhook/route.ts (webhook handler runs without a user session)
#   - app/api/pools/record-deployment/route.ts (writes to user_pool_deployments)
#   - scripts/backfill-pool-owner-memberships.mjs (one-off maintenance)
# Never set NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY (the NEXT_PUBLIC_ prefix
# would expose it to the browser bundle).

# --- Stripe (Pro subscription, $20/month) ---
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring price ID for the Pro plan ($20 USD/month). Create the product+price
# in the Stripe dashboard, then paste the `price_...` ID here.
# STRIPE_PRO_MONTHLY_PRICE_ID=
# Signing secret from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# (or the dashboard endpoint signing secret in production).
# STRIPE_WEBHOOK_SECRET=
# Public app origin used for Checkout success/cancel URLs and Billing Portal returns.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PostHog product analytics ---
# Project API key (Project Settings -> Project API Key), safe to expose in browser.
# NEXT_PUBLIC_POSTHOG_TOKEN=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PostHog ingestion host (US cloud shown; use EU/self-hosted host when applicable).
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional local kill-switch for browser analytics initialization.
# NEXT_PUBLIC_POSTHOG_DISABLED=false

# Optional: `alchemy` (default when ALCHEMY_API_KEY is set) or `etherscan` to force a provider.
# EVM_LOOKUP_PROVIDER=etherscan

# Optional: cap Etherscan account history pages per list type (1–8). Lower = faster cold lookups.
# ETHERSCAN_TX_MAX_PAGES=3

# Optional: cap Alchemy `alchemy_getAssetTransfers` pages per direction (1–8).
# ALCHEMY_ASSET_TRANSFER_MAX_PAGES=8

# Optional: set to `1` to log structured `onchain_lookup_timing` lines from `runOnchainLookup`.
# ONCHAIN_LOOKUP_TIMING=1

# --- Expected chain (deploy-broadcast guard + wallet network warning) ---
# Read by `lib/wallet/expected-chain.ts` and `lib/onchain/community-pool.ts`. The deploy path
# refuses to broadcast if the connected wallet's chain doesn't match this value, so a mainnet
# build can't accidentally deploy a pool while connected to Sepolia (or vice versa).
#   Local dev / Sepolia testing: 11155111
#   Mainnet launch: set to 1 in the hosting-platform env, NOT in local .env.
# If unset, the app defaults to Sepolia (11155111).
# NEXT_PUBLIC_EXPECTED_CHAIN_ID=11155111

# --- Ethereum mainnet (chain 1) ---
# CommunityPool uses built-in platform addresses for ETH/USD and default ERC20 presets
# (WBTC, PAXG, XAU₮). No NEXT_PUBLIC token addresses are required for mainnet.

# --- Local Anvil (chain 31337) ---
# Required for MetaMask + CommunityPool deploy on local Anvil.
# After `forge script script/DeployCommunityPool.s.sol:DeployCommunityPool --rpc-url http://127.0.0.1:8545 --broadcast`,
# use the MockV3Aggregator address from `broadcast/.../run-latest.json` (first CREATE) or the console.
# On a fresh Anvil instance with the default account ordering, this is often:
# NEXT_PUBLIC_LOCAL_ETH_USD_FEED=0x5FbDB2315678afecb367f032d93F642f64180aa3

# --- Sepolia (chain 11155111) ---
# If a token's _TOKEN + _USD_FEED vars are unset, that ERC20 is OFF on Sepolia (no fallback to
# mainnet addresses — those contracts don't exist on Sepolia). Sepolia stays ETH-only by default.
# Set the variables below only if you've deployed mock PAXG/XAU₮/WBTC ERC20s on Sepolia and
# want to exercise the ERC20 funding flow against a real RPC. Decimals default to canonical
# mainnet values (8 / 18 / 6) when omitted.

# NEXT_PUBLIC_SEPOLIA_WBTC_TOKEN=
# NEXT_PUBLIC_SEPOLIA_WBTC_USD_FEED=
# NEXT_PUBLIC_SEPOLIA_WBTC_DECIMALS=8

# NEXT_PUBLIC_SEPOLIA_PAXG_TOKEN=
# NEXT_PUBLIC_SEPOLIA_PAXG_USD_FEED=
# NEXT_PUBLIC_SEPOLIA_PAXG_DECIMALS=18

# NEXT_PUBLIC_SEPOLIA_XAUT_TOKEN=
# NEXT_PUBLIC_SEPOLIA_XAUT_USD_FEED=
# NEXT_PUBLIC_SEPOLIA_XAUT_DECIMALS=6

# --- Open Pools chain reads ---
# `/api/pools/balances` uses the server-side Alchemy credentials below so the
# Open Pools table reflects actual on-chain balances even when the user has
# no wallet connected. `ALCHEMY_API_KEY` alone is sufficient; use the per-
# network URLs when you need a dedicated endpoint.
#
# ALCHEMY_API_KEY=
# ALCHEMY_API_URL_ETH_MAINNET=
# ALCHEMY_API_URL_ETH_SEPOLIA=
# LOCAL_ANVIL_RPC_URL=http://127.0.0.1:8545
# Optional per-chain override for backfill RPC source:
# BACKFILL_RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/<key>
# BACKFILL_RPC_URL_11155111=https://eth-sepolia.g.alchemy.com/v2/<key>
# BACKFILL_RPC_URL_31337=http://127.0.0.1:8545

# Optional browser-side read fallback for chains when the server route is
# unavailable. If unset, the client falls back to the public RPCs listed in
# CHAIN_METADATA, which are rate-limited and often flaky.
# NEXT_PUBLIC_READ_RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/<public-key>
# NEXT_PUBLIC_READ_RPC_URL_11155111=https://eth-sepolia.g.alchemy.com/v2/<public-key>

# --- Open Pools reconciliation debug ---
# Set to `1` to log `[pool-debug] reconcile` on every chain read; useful for
# diagnosing Amount / Balance (USD) mismatches against the block explorer.
# NEXT_PUBLIC_POOL_DEBUG=1
