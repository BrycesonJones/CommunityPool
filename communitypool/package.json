{
  "name": "communitypool",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:balance": "node scripts/verify-balance-lookup.mjs",
    "backfill:pool-owners": "node scripts/backfill-pool-owner-memberships.mjs",
    "scan:bundle-secrets": "node scripts/scan-bundle-secrets.mjs",
    "scan:bundle-secrets:ci": "node scripts/scan-bundle-secrets.mjs --require-build",
    "contracts:sync-artifact": "node scripts/sync-contract-artifact.mjs",
    "contracts:check-artifact": "node scripts/sync-contract-artifact.mjs --check",
    "supply-chain:check": "node scripts/supply-chain-check.mjs",
    "sbom": "cyclonedx-npm --output-format json --output-file sbom.json --omit dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ethers": "^6.13.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "posthog-js": "^1.372.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
